# Environment Configuration Template
# Copy this file to .env and fill in your values
# NEVER commit .env file to repository - it contains sensitive data!

# Application Environment
APP_ENV=development
APP_DEBUG=false

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_NAME=hmisphp

# Database Connection Pool
DB_POOL_SIZE=10
DB_POOL_TIMEOUT=30

# Server Configuration
NGINX_PORT=80
PMA_PORT=8081
PHP_PORT=9000

# Session Configuration
SESSION_TIMEOUT=1800
SESSION_NAME=HMIS_SESSION

# Security Settings
HASH_ALGORITHM=bcrypt
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# Email Configuration (for password resets)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@hospital.local

# File Upload Configuration
MAX_UPLOAD_SIZE=5242880
ALLOWED_UPLOAD_TYPES=jpg,jpeg,png,gif
UPLOAD_DIR=assets/images/uploads

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=error
LOG_PATH=logs/

# AWS Configuration (Optional - for production deployment)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
