# Environment Configuration File
# Copy to .env and update with your values

# Application Settings
APP_ENV=production
APP_NAME="Hospital Management System"
APP_DEBUG=false
APP_URL=http://localhost

# Database Configuration
DB_HOST=db
DB_PORT=3306
DB_NAME=hmisphp
DB_USER=hospital
DB_PASSWORD=pramod2004
DB_ROOT_PASSWORD=pramod2004

# Server Configuration
NGINX_PORT=80
NGINX_SSL_PORT=443
PHP_ENV=production

# Cache Configuration
REDIS_PORT=6379
CACHE_DRIVER=redis

# Admin Credentials (Change in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=pramod2004

# Doctor Default Credentials (Change in production!)
DOCTOR_USERNAME=admin
DOCTOR_PASSWORD=pramod2004

# Mail Configuration (Optional)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_username
MAIL_PASSWORD=your_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@hospital.local

# SSL Configuration
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# AWS Configuration (If deploying to AWS)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=

# PHPMyAdmin Port (Development only)
PMA_PORT=8081
